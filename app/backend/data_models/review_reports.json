{
    "title": "review_reports",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Primary key, auto-increment"
        },
        "user_id": {
            "type": "string",
            "description": "Owner user id"
        },
        "document_id": {
            "type": "integer",
            "description": "Related document id"
        },
        "contract_type": {
            "type": "string",
            "description": "Contract type e.g. lease/sales/service"
        },
        "user_role": {
            "type": "string",
            "description": "User role e.g. party_a/party_b"
        },
        "risk_score": {
            "type": "integer",
            "description": "Risk score 0-100"
        },
        "risk_level": {
            "type": "string",
            "description": "Risk level: low/medium/high/critical"
        },
        "signing_recommendation": {
            "type": "string",
            "description": "Recommendation: sign/modify_then_sign/caution/do_not_sign"
        },
        "executive_summary": {
            "type": "string",
            "description": "Executive summary text"
        },
        "contract_basic_info": {
            "type": "string",
            "description": "JSON of contract basic info"
        },
        "risk_matrix": {
            "type": "string",
            "description": "JSON of risk matrix counts"
        },
        "missing_clause_checklist": {
            "type": "string",
            "description": "JSON of missing clause checklist"
        },
        "favorable_clauses": {
            "type": "string",
            "description": "JSON of favorable clauses"
        },
        "legal_source_appendix": {
            "type": "string",
            "description": "JSON of legal source appendix"
        },
        "disclaimer": {
            "type": "string",
            "description": "Disclaimer text"
        },
        "status": {
            "type": "string",
            "description": "Status: pending/processing/completed/failed"
        },
        "is_paid": {
            "type": "boolean",
            "description": "Whether full report is unlocked"
        }
    },
    "required": [
        "id",
        "user_id",
        "document_id"
    ]
}