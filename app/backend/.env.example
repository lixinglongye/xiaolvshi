DATABASE_URL=sqlite+aiosqlite:///./dev.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# OpenAI-compatible model gateway used by services/aihub.py
APP_AI_BASE_URL=https://yibuapi.com/v1
APP_AI_KEY=replace-with-your-key
APP_AI_CHEAP_MODEL=gemini-2.5-flash-lite
APP_AI_BALANCED_MODEL=gemini-2.5-flash
APP_AI_PREMIUM_MODEL=gemini-2.5-pro
APP_OCR_MODEL=gemini-2.5-flash-lite
APP_AI_FAST_MODEL=gemini-2.5-flash-lite
APP_AI_CLASSIFIER_MODEL=gemini-2.5-flash-lite
APP_AI_REVIEW_MODEL=gemini-2.5-flash
APP_AI_PDF_MODEL=gemini-2.5-pro
APP_AI_REQUEST_TIMEOUT=360
APP_AI_PREMIUM_REQUIRES_REVIEW=true

# PDF OCR tuning. Text-layer PDF parsing is always tried first; OCR only runs on low-text/scanned pages.
PDF_OCR_DPI=180
PDF_OCR_MAX_PAGES=40
PDF_OCR_TESSERACT_LANG=chi_sim+eng

# Object storage service used by uploaded-document analysis
# If OSS_SERVICE_URL/OSS_API_KEY are omitted in local development, files are stored under app/backend/local_storage.
OSS_SERVICE_URL=https://your-oss-service.example.com/
OSS_API_KEY=replace-with-your-oss-key
LOCAL_STORAGE_DIR=./local_storage

# Optional local/demo seed data. Keep disabled in production.
ALLOW_SEED_DATA=false

# Optional local admin bootstrap
ADMIN_USER_ID=
ADMIN_USER_EMAIL=

# Optional payment settings
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
