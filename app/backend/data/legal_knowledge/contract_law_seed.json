    {
      "source_id": "CIVIL-919",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第九百一十九条",
      "article_title": "委托合同定义",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["委托合同", "服务合同", "代理事项"],
      "keywords": ["委托合同", "委托人", "受托人", "处理事务"],
      "text": "委托合同是委托人和受托人约定，由受托人处理委托人事务的合同。",
      "summary": "用于审查代理、代办、顾问、咨询、管理服务等委托关系。",
      "legal_effect_note": "委托合同应明确授权范围、转委托、费用报销、报告义务、成果归属和任意解除后果。",
