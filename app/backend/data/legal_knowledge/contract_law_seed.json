    {
      "source_id": "CIVIL-771",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百七十一条",
      "article_title": "承揽合同内容",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["承揽合同", "条款完备性", "成果验收"],
