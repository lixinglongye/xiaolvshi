    },
    {
      "source_id": "CIVIL-533",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百三十三条",
      "article_title": "情势变更",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["合同履行", "情势变更", "风险分担"],
      "keywords": ["情势变更", "不可预见", "商业风险", "重新协商", "变更解除"],
      "text": "合同成立后基础条件发生当事人订立合同时无法预见且不属于商业风险的重大变化，继续履行明显不公平的，受不利影响一方可以与对方重新协商；协商不成可请求变更或者解除合同。",
      "summary": "用于长期合同、价格波动、供应链中断、政策变化等场景的风险分担设计。",
      "legal_effect_note": "应与不可抗力、价格调整、变更管理、通知期限和证据义务条款联动设计。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-562",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百六十二条",
      "article_title": "协议解除和约定解除",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["合同解除", "约定解除", "退出机制"],
      "keywords": ["协商一致解除", "解除事由", "解除权", "约定解除"],
      "text": "当事人协商一致，可以解除合同；当事人可以约定一方解除合同的事由，解除事由发生时，解除权人可以解除合同。",
      "summary": "用于审查合同是否具备清晰的退出条件和解除流程。",
      "legal_effect_note": "建议明确解除触发事件、通知方式、整改期、结算规则和资料返还义务。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-563",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百六十三条",
      "article_title": "法定解除",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["合同解除", "根本违约", "不可抗力"],
      "keywords": ["法定解除", "不可抗力", "迟延履行", "根本违约", "合同目的不能实现"],
      "text": "因不可抗力致使不能实现合同目的，或一方迟延履行主要债务经催告后仍不履行等法定情形下，当事人可以解除合同。",
      "summary": "用于判断是否存在法定解除路径，尤其是根本违约和合同目的不能实现。",
      "legal_effect_note": "合同应明确催告、宽限期、解除通知到达和解除后费用结算规则。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-565",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百六十五条",
      "article_title": "解除通知和异议",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["合同解除", "通知", "解除程序"],
      "keywords": ["解除通知", "通知到达", "自动解除", "异议期限", "确认解除"],
      "text": "当事人一方依法主张解除合同的，应当通知对方；合同自通知到达对方时解除，法律另有规定或者当事人另有约定的除外。",
      "summary": "用于审查解除程序条款是否能落地，包括送达地址、电子送达、异议期限。",
      "legal_effect_note": "建议把通知方式、送达视为到达规则和争议处理衔接写清楚。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-566",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百六十六条",
      "article_title": "合同解除后果",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["合同解除", "恢复原状", "赔偿损失", "结算清理"],
      "keywords": ["解除后果", "恢复原状", "补救措施", "赔偿损失", "结算清理"],
      "text": "合同解除后，尚未履行的终止履行；已经履行的，根据履行情况和合同性质，当事人可以请求恢复原状或者采取其他补救措施，并有权请求赔偿损失。",
      "summary": "用于审查解除后的返还、结算、数据移交、保密和违约责任是否完备。",
      "legal_effect_note": "持续性服务合同尤其应增加已履行部分计费、成果移交、预付款退还和善后义务。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-577",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百七十七条",
      "article_title": "违约责任一般规则",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["违约责任", "继续履行", "补救措施", "赔偿损失"],
      "keywords": ["违约责任", "不履行", "履行不符合约定", "继续履行", "赔偿损失"],
      "text": "当事人一方不履行合同义务或者履行合同义务不符合约定的，应当承担继续履行、采取补救措施或者赔偿损失等违约责任。",
      "summary": "合同违约责任审查的基础条款，可用于识别责任类型是否完整。",
      "legal_effect_note": "违约条款应覆盖付款逾期、交付迟延、质量瑕疵、保密违约、知识产权侵权等具体场景。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-584",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百八十四条",
      "article_title": "损害赔偿范围",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["违约责任", "损害赔偿", "可得利益"],
      "keywords": ["赔偿损失", "合同履行后可以获得的利益", "可预见规则", "不得超过"],
      "text": "一方违约造成对方损失的，赔偿额应相当于因违约所造成的损失，包括合同履行后可以获得的利益，但不得超过违约方订约时预见或者应当预见的损失。",
      "summary": "用于审查损失赔偿范围、间接损失、利润损失、责任上限的合理性。",
      "legal_effect_note": "建议明确赔偿范围、排除/包含间接损失、责任限额和例外情形。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-585",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百八十五条",
      "article_title": "违约金",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["违约责任", "违约金", "责任调整"],
      "keywords": ["违约金", "损失赔偿额", "过分高于损失", "增加减少", "迟延履行"],
      "text": "当事人可以约定违约金或者损失赔偿额计算方法；约定违约金低于或过分高于造成的损失的，当事人可以请求人民法院或者仲裁机构调整。",
      "summary": "用于审查违约金比例、逾期付款罚则、责任上限是否存在被调整风险。",
      "legal_effect_note": "报告应提示违约金不能机械堆叠，需结合实际损失、履行利益和举证可行性。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-590",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百九十条",
      "article_title": "不可抗力",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["不可抗力", "免责", "通知证明"],
      "keywords": ["不可抗力", "免除责任", "及时通知", "证明", "迟延履行后发生"],
      "text": "当事人一方因不可抗力不能履行合同的，根据不可抗力影响部分或者全部免除责任，但法律另有规定的除外；当事人迟延履行后发生不可抗力的，不免除其违约责任。",
      "summary": "用于审查不可抗力条款是否包含范围、通知、证明、减损和迟延履行例外。",
      "legal_effect_note": "不可抗力并非当然免责，应要求及时通知、证明材料和影响范围说明。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-596",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第五百九十六条",
      "article_title": "买卖合同内容",
