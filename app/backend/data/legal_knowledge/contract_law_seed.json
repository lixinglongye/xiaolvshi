      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["借款合同", "合同成立", "交付"],
      "keywords": ["自然人借款", "提供借款", "合同成立", "交付"],
      "text": "自然人之间的借款合同，自贷款人提供借款时成立。",
      "summary": "用于识别借条签署与款项实际交付之间的成立风险。",
      "legal_effect_note": "自然人借款报告应提示保留银行转账、收据、聊天确认和资金来源证据。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-680",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第六百八十条",
      "article_title": "禁止高利放贷",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["借款合同", "利率", "高利放贷"],
      "keywords": ["禁止高利放贷", "利率", "国家有关规定", "未约定利息", "视为没有利息"],
      "text": "禁止高利放贷，借款的利率不得违反国家有关规定；借款合同对支付利息没有约定的，视为没有利息。",
      "summary": "用于审查借款利率、复利、服务费、咨询费等综合资金成本是否合法。",
      "legal_effect_note": "具体利率上限需结合民间借贷司法解释和最新一年期 LPR 规则另行核验。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-681",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第六百八十一条",
      "article_title": "保证合同定义",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["保证合同", "担保", "债务履行"],
      "keywords": ["保证合同", "保证人", "债权人", "债务人", "履行债务", "承担责任"],
      "text": "保证合同是为保障债权实现，保证人和债权人约定，当债务人不履行到期债务或者发生约定情形时，保证人履行债务或者承担责任的合同。",
      "summary": "用于审查担保安排是否形成保证法律关系及保证责任触发条件。",
      "legal_effect_note": "应明确被担保债权、保证范围、保证方式、保证期间和最高额担保边界。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-686",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第六百八十六条",
      "article_title": "保证方式",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["保证合同", "一般保证", "连带责任保证"],
      "keywords": ["一般保证", "连带责任保证", "没有约定", "约定不明确"],
      "text": "保证的方式包括一般保证和连带责任保证；当事人在保证合同中对保证方式没有约定或者约定不明确的，按照一般保证承担保证责任。",
      "summary": "用于审查保证条款是否明确连带责任，否则可能按一般保证处理。",
      "legal_effect_note": "债权人版本如需连带保证，应使用清晰、直接、无歧义的连带责任表述。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-692",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第六百九十二条",
      "article_title": "保证期间",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["保证合同", "保证期间", "担保风险"],
      "keywords": ["保证期间", "主债务履行期限", "六个月", "约定不明确"],
      "text": "保证期间是确定保证人承担保证责任的期间，不发生中止、中断和延长；没有约定或者约定不明确的，保证期间为主债务履行期限届满之日起六个月。",
      "summary": "用于审查保证期间是否明确、是否与主债务期限和提前到期条款衔接。",
      "legal_effect_note": "保证期间过短或起算不清会直接影响债权实现，应在报告中作为高风险项提示。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-703",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百零三条",
      "article_title": "租赁合同定义",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "租金", "使用收益"],
      "keywords": ["租赁合同", "出租人", "承租人", "使用收益", "支付租金"],
      "text": "租赁合同是出租人将租赁物交付承租人使用、收益，承租人支付租金的合同。",
      "summary": "用于识别租赁合同基本权利义务，覆盖房屋、设备、车辆等租赁场景。",
      "legal_effect_note": "租赁报告应关注租赁物状态、用途限制、维修义务、转租、押金和提前解除。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-704",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百零四条",
      "article_title": "租赁合同内容",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "条款完备性", "租金期限"],
      "keywords": ["租赁物名称", "数量", "用途", "租赁期限", "租金", "维修"],
      "text": "租赁合同的内容一般包括租赁物的名称、数量、用途、租赁期限、租金及其支付期限和方式、租赁物维修等条款。",
      "summary": "用于租赁合同审查清单，尤其是用途、期限、租金支付和维修责任。",
      "legal_effect_note": "房屋租赁还应补充权属证明、消防合规、装修恢复、备案和转租授权。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-705",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百零五条",
      "article_title": "租赁期限上限",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "租赁期限", "期限上限"],
      "keywords": ["租赁期限", "二十年", "超过部分无效", "续订"],
      "text": "租赁期限不得超过二十年；超过二十年的，超过部分无效。租赁期限届满，当事人可以续订租赁合同。",
      "summary": "用于审查长期租赁、商业物业租赁和续租安排的效力风险。",
      "legal_effect_note": "若需长期占有使用，应考虑分期续租、优先续租权和登记备案等配套条款。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-707",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百零七条",
      "article_title": "租赁书面形式",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "书面形式", "不定期租赁"],
      "keywords": ["六个月以上", "书面形式", "不定期租赁"],
      "text": "租赁期限六个月以上的，应当采用书面形式；当事人未采用书面形式，无法确定租赁期限的，视为不定期租赁。",
      "summary": "用于审查租赁期限和书面合同证据风险。",
      "legal_effect_note": "未书面约定长期租赁可能被认定为不定期租赁，影响稳定使用和解除预期。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-712",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百一十二条",
      "article_title": "出租人维修义务",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "维修义务", "租赁物状态"],
      "keywords": ["出租人", "维修义务", "另有约定"],
      "text": "出租人应当履行租赁物的维修义务，但是当事人另有约定的除外。",
      "summary": "用于审查维修责任分配是否清楚，尤其是房屋主体结构、设备设施、易耗品。",
      "legal_effect_note": "建议区分日常维护、重大维修、承租人原因损坏和紧急维修费用承担。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-713",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百一十三条",
      "article_title": "承租人请求维修权利",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "维修义务", "减少租金"],
      "keywords": ["维修", "合理期限", "自行维修", "减少租金", "延长租期"],
      "text": "承租人在租赁物需要维修时可以请求出租人在合理期限内维修；出租人未履行维修义务的，承租人可以自行维修，维修费用由出租人负担。",
      "summary": "用于审查维修响应期限、自行维修授权、费用抵扣和租金减免机制。",
      "legal_effect_note": "承租人版本应保留紧急维修权和费用抵扣权；出租人版本应设置通知和审核流程。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-716",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百一十六条",
      "article_title": "转租",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "转租", "出租人同意"],
      "keywords": ["转租", "出租人同意", "解除合同", "承租人责任"],
      "text": "承租人经出租人同意，可以将租赁物转租给第三人；承租人未经出租人同意转租的，出租人可以解除合同。",
      "summary": "用于审查转租、分租、共享办公、场地合作等安排是否获得授权。",
      "legal_effect_note": "建议明确可否转租、审批流程、转租收益、第三人违约和原承租人责任。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-730",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百三十条",
      "article_title": "不定期租赁",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["租赁合同", "不定期租赁", "解除"],
      "keywords": ["租赁期限没有约定", "不明确", "不定期租赁", "随时解除", "合理期限"],
      "text": "当事人对租赁期限没有约定或者约定不明确，依法仍不能确定的，视为不定期租赁；当事人可以随时解除合同，但应在合理期限之前通知对方。",
      "summary": "用于审查租赁期限缺失、续租未签约和事实租赁的稳定性风险。",
      "legal_effect_note": "长期经营场所应避免不定期租赁状态，明确续租期限、通知期和搬迁补偿安排。",
      "source_url": "https://wb.flk.npc.gov.cn/flfg/PDF/bd53dd912c1048f2aecbaa229238334b.pdf",
      "official_source_url": "https://flk.npc.gov.cn/",
      "effective_status": "现行有效",
      "verification_status": "已校验",
      "published_at": "2020-05-28",
      "effective_at": "2021-01-01"
    },
    {
      "source_id": "CIVIL-770",
      "source_name": "《中华人民共和国民法典》",
      "article_number": "第七百七十条",
      "article_title": "承揽合同定义",
      "source_type": "法律",
      "authority_level": "裁判依据",
      "jurisdiction": "中国大陆",
      "legal_domain": "合同审查",
      "topics": ["承揽合同", "服务交付", "成果验收"],
